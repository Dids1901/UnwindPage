{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "firestore.rules",
      ".firebaserc",
      ".firebase",
      ".firebase/**",
      "firebase-debug.log",
      ".git",
      ".git/**",
      ".vscode",
      ".vscode/**",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/beta.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
